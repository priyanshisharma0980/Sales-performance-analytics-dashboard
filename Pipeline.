### Azure Synapse Code

IF NOT EXISTS (SELECT * FROM sys.databases WHERE name = 'nyc_taxi_db')
BEGIN
    CREATE DATABASE nyc_taxi_db;
END
GO

USE nyc_taxi_db;
GO

-- NYC Public Dataset
IF NOT EXISTS (SELECT * FROM sys.external_data_sources WHERE name = 'nyc_taxi_source')
BEGIN
    CREATE EXTERNAL DATA SOURCE nyc_taxi_source
    WITH (
        LOCATION = 'https://azureopendatastorage.blob.core.windows.net/nyctlc'
    );
END
GO


-- Your Storage Account (Target)
IF NOT EXISTS (SELECT * FROM sys.external_data_sources WHERE name = 'adf_storage')
BEGIN
    CREATE EXTERNAL DATA SOURCE adf_storage
    WITH (
        LOCATION = 'https://adfstorageacc.blob.core.windows.net/adftarget'
    );
END
GO

CREATE OR ALTER VIEW dbo.nyc_taxi_bronze AS
SELECT
    vendorID,
    tpepPickupDateTime,
    tpepDropoffDateTime,
    passengerCount,
    tripDistance,
    puLocationId,
    doLocationId,
    fareAmount,
    tipAmount,
    totalAmount,
    paymentType
FROM
    OPENROWSET(
        BULK 'yellow/puYear=*/puMonth=*/*.parquet',
        DATA_SOURCE = 'nyc_taxi_source',
        FORMAT = 'PARQUET'
    ) AS result;
GO


CREATE OR ALTER VIEW dbo.nyc_taxi_silver AS
SELECT *
FROM dbo.nyc_taxi_bronze
WHERE fareAmount > 0
  AND tripDistance > 0
  AND passengerCount > 0;
GO


CREATE OR ALTER VIEW dbo.nyc_taxi_gold AS
SELECT
    *,
    DATEDIFF(MINUTE, tpepPickupDateTime, tpepDropoffDateTime) AS trip_duration_minutes,
    fareAmount / NULLIF(tripDistance, 0) AS fare_per_mile,
    tipAmount / NULLIF(fareAmount, 0) AS tip_percentage
FROM dbo.nyc_taxi_silver;
GO

IF NOT EXISTS (SELECT * FROM sys.external_file_formats WHERE name = 'parquet_format')
BEGIN
    CREATE EXTERNAL FILE FORMAT parquet_format
    WITH (
        FORMAT_TYPE = PARQUET
    );
END
GO
IF EXISTS (SELECT * FROM sys.external_tables WHERE name = 'nyc_taxi_gold_ext')
BEGIN
    DROP EXTERNAL TABLE dbo.nyc_taxi_gold_ext;
END
GO
CREATE EXTERNAL TABLE dbo.nyc_taxi_gold_ext
WITH (
    LOCATION = 'gold/',
    DATA_SOURCE = adf_storage,
    FILE_FORMAT = parquet_format
)
AS
SELECT *
FROM dbo.nyc_taxi_gold;
GO
